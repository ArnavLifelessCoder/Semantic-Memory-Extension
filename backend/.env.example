# =============================================================================
# Semantic Memory API — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# =============================================================================

# --- Database ---
# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/semantic_memory

# --- Redis ---
# Redis connection string (for job queue + session cache)
REDIS_URL=redis://localhost:6379

# --- Authentication ---
# IMPORTANT: Change this to a strong random value in production!
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# JWT signing algorithm (HS256 is recommended)
JWT_ALGORITHM=HS256

# Token expiry in hours (default: 72 = 3 days)
JWT_EXPIRY_HOURS=72

# --- Google OAuth2 (optional) ---
# Leave empty to disable Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Encryption ---
# Salt used for client-side PBKDF2 key derivation
# Only change this if you know what you're doing — changing it
# invalidates all existing encrypted sync snapshots
ENCRYPTION_KEY_SALT=semantic-memory-salt-v1
